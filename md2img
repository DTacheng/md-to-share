#!/bin/bash
# md2img - Markdown 转原生长图工具
# 使用 Playwright 内置 Chromium 渲染 Markdown 为长图

set -e

# 解析 symlink，找到脚本真实所在目录（macOS 兼容）
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# 透传所有参数给 Node 脚本（md2img.mjs 内置参数解析器）
cd "$SCRIPT_DIR"
exec node md2img.mjs "$@"
